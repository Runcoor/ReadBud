{
  "manifest_version": 3,
  "name": "ReadBud · WeChat 自动填充",
  "version": "0.1.0",
  "description": "在微信公众号编辑器自动填充 ReadBud 生成的标题、正文与封面图。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mp.weixin.qq.com/*",
    "http://localhost:8080/*",
    "http://localhost:8081/*",
    "http://127.0.0.1:8080/*",
    "http://127.0.0.1:8081/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ReadBud · WeChat 自动填充"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/cgi-bin/appmsg*"],
      "js": ["content_script.js"],
      "css": ["content_script.css"],
      "run_at": "document_idle"
    }
  ]
}
